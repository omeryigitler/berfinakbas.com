{
  "name": "berfinakbas-com",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build:dashboard-source": "node scripts/build-dashboard-source.mjs",
    "build": "pnpm build:dashboard-source && prisma generate && if [ \"${VERCEL_ENV:-development}\" = \"production\" ]; then prisma migrate deploy && pnpm tsx scripts/activate-booking-test-data.ts; fi && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "next typegen && tsc --noEmit",
    "test": "vitest run",
    "test:integration": "node scripts/run-postgres-integration-tests.mjs",
    "test:visual": "python3 tests/visual/prepare-reference.py && pnpm dlx @playwright/test@1.61.1 test --config tests/visual/playwright.config.mjs",
    "test:visual:compare": "python3 tests/visual/prepare-reference.py && python3 tests/visual/compare.py",
    "test:visual:deps": "pnpm dlx playwright@1.61.1 install --with-deps chromium && python3 -m pip install --disable-pip-version-check Pillow==12.3.0",
    "test:watch": "vitest",
    "quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm format:check",
    "db:validate": "prisma validate",
    "db:format": "prisma format",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "test:smoke": "node scripts/run-production-smoke-tests.mjs"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.3",
    "@fontsource-variable/inter": "^5.3.0",
    "@prisma/adapter-pg": "7.9.0",
    "@prisma/client": "7.9.0",
    "botid": "^1.5.11",
    "dotenv": "17.4.2",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.32",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.1",
    "@types/node": "26.0.1",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "10.1.8",
    "postcss": "8.5.15",
    "prettier": "3.9.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "prisma": "7.8.0",
    "tailwindcss": "4.3.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
